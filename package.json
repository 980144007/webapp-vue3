    "serve:test": "set NODE_ENV=development&& vite  --mode test",
    "start:test": "set NODE_ENV=development&& vite  --mode test",
    "build:test": "set NODE_ENV=production&& vite build  --mode test",
    "dev:prod": "set NODE_ENV=development&& vite --mode prod",
